// Copy to Secrets.xcconfig and fill in your Supabase project values.
// Use the publishable (anon) key only — never the secret / service_role key.
// Secrets.xcconfig is gitignored.

// Optional — only if you want xcodegen to pin your team (10-char ID from Xcode → Settings → Accounts):
// DEVELOPMENT_TEAM = XXXXXXXXXX

// URL must use https:/$()/ to avoid // being treated as an xcconfig comment
SUPABASE_URL = https:/$()/your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-publishable-key-here
